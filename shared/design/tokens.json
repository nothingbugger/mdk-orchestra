{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "name": "MDK TUI",
  "description": "Design tokens for MDK 2.0 dashboards. Dark-slate TUI style inspired by mactop: cream borders on dark background, mint mining-green accent, JetBrains Mono everywhere. Hand-made for the Tether MDK assignment.",
  "version": "1.0.0",

  "color": {
    "bg": {
      "base":    { "value": "#1b2430", "description": "page background — deep slate, warm blue undertone" },
      "soft":    { "value": "#222d3b", "description": "panel interior surface (default panels)" },
      "hero":    { "value": "#243242", "description": "hero-panel interior (optimizer / predicter, anything highlighted)" },
      "dot":     { "value": "rgba(212, 201, 152, 0.08)", "description": "row-hover tint over soft bg" }
    },
    "border": {
      "base":    { "value": "#d4c998", "description": "panel border — warm cream, mactop-style" },
      "dim":     { "value": "#8a8366", "description": "muted divider inside panels" },
      "row":     { "value": "rgba(212, 201, 152, 0.22)", "description": "dotted row separator" }
    },
    "text": {
      "primary": { "value": "#e8e4d4", "description": "primary body text — off-white cream" },
      "dim":     { "value": "#9da89a", "description": "secondary text / labels" },
      "mute":    { "value": "#6b7280", "description": "tertiary / timestamps / inactive" }
    },
    "status": {
      "ok":      { "value": "#9dc797", "description": "mint — healthy, positive gain, primary accent" },
      "ok-glow": { "value": "#b8dab2", "description": "brighter mint for hero numbers" },
      "warn":    { "value": "#e4c571", "description": "yellow — warning tier (TTF 6–24h, thermal drift)" },
      "alert":   { "value": "#d97706", "description": "amber — operational alert / marker highlight" },
      "alert-soft": { "value": "#fde8c7", "description": "amber wash (rare)" },
      "crit":    { "value": "#e26d6d", "description": "red — critical (TTF <6h, shutdowns, failures)" },
      "shut":    { "value": "#6b7280", "description": "grey — shutdown blocks (= text.mute)" }
    },
    "plot": {
      "grid":    { "value": "rgba(212, 201, 152, 0.18)", "description": "plotly gridline color" },
      "paper-transparent": { "value": "rgba(0,0,0,0)", "description": "plotly paper_bgcolor — transparent so chart inherits panel bg" },
      "fill-mint-soft":    { "value": "rgba(157, 199, 151, 0.10)", "description": "light area-fill under sparkline" }
    },
    "alpha": {
      "ok-fill":   { "value": "rgba(157, 199, 151, 0.14)", "description": "callout bg for ok kind" },
      "warn-fill": { "value": "rgba(228, 197, 113, 0.14)", "description": "callout bg for warn kind" },
      "crit-fill": { "value": "rgba(226, 109, 109, 0.18)", "description": "callout bg for crit kind" },
      "alert-fill": { "value": "rgba(217, 119, 6, 0.10)", "description": "callout bg for alert kind" }
    }
  },

  "typography": {
    "fontFamily": {
      "mono":  { "value": "'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, monospace", "description": "all body + data text" },
      "hand":  { "value": "'Kalam', 'Caveat', cursive", "description": "wireframe annotations only (rare use)" }
    },
    "fontSize": {
      "tiny":   { "value": "10px", "description": "row numbers, kind tags, sub-labels" },
      "label":  { "value": "11px", "description": "panel labels, KPI labels, legends" },
      "small":  { "value": "11px", "description": "compact lists, scroll rows" },
      "body":   { "value": "13px", "description": "default body text" },
      "header": { "value": "13px", "description": "header bar titles" },
      "big":    { "value": "22px", "description": "secondary big numbers" },
      "kpi":    { "value": "28px", "description": "headline KPI numbers" },
      "hero":   { "value": "34px", "description": "hero-panel primary metric" }
    },
    "fontWeight": {
      "normal": { "value": 400 },
      "medium": { "value": 500 },
      "bold":   { "value": 700 }
    },
    "lineHeight": {
      "tight":  { "value": 1.3 },
      "normal": { "value": 1.5 }
    },
    "letterSpacing": {
      "tiny":   { "value": "0.3px", "description": "dropdowns, option rows" },
      "small":  { "value": "0.8px", "description": "buttons, subtle caps" },
      "label":  { "value": "1.2px", "description": "panel labels, kind tags" },
      "kpi":    { "value": "1.4px", "description": "KPI labels" },
      "strong": { "value": "1.8px", "description": "section labels, emphasised caps" }
    }
  },

  "spacing": {
    "0": { "value": "0" },
    "1": { "value": "4px" },
    "2": { "value": "8px" },
    "3": { "value": "12px" },
    "4": { "value": "16px" },
    "5": { "value": "24px" },
    "6": { "value": "32px" }
  },

  "border": {
    "width": {
      "thin":   { "value": "1px" },
      "strong": { "value": "1.5px" }
    },
    "style": {
      "panel":     { "value": "1px solid #d4c998", "description": "default panel border" },
      "hero":      { "value": "1.5px solid #9dc797", "description": "highlighted hero panels (optimizer/predicter)" },
      "dimDashed": { "value": "1px dashed #8a8366", "description": "internal section divider" },
      "rowDotted": { "value": "1px dotted rgba(212, 201, 152, 0.22)", "description": "log/feed row separator" }
    }
  },

  "radius": {
    "none":   { "value": "0", "description": "TUI feel — sharp corners everywhere" }
  },

  "component": {
    "panel": {
      "padding":    { "value": "16px 18px 14px 18px" },
      "paddingHero":{ "value": "22px 22px 20px" }
    },
    "cell": {
      "height":     { "value": "24px", "description": "heatmap cell height" },
      "gap":        { "value": "4px",  "description": "heatmap cell gap" }
    },
    "bar": {
      "height":     { "value": "24px", "description": "status / progress bar default" }
    },
    "fleet": {
      "maxCols":    { "value": 10, "description": "heatmap grid — max miner slots per model row" }
    }
  },

  "plotly": {
    "layout": {
      "paper_bgcolor": "rgba(0,0,0,0)",
      "plot_bgcolor":  "rgba(0,0,0,0)",
      "margin":        { "l": 4, "r": 4, "t": 4, "b": 4 },
      "font":          { "family": "'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, monospace", "size": 11, "color": "#9da89a" },
      "showlegend":    false,
      "transition":    { "duration": 500, "easing": "cubic-in-out" }
    },
    "axis_hidden": {
      "showgrid":       false,
      "showticklabels": false,
      "zeroline":       false,
      "showline":       false
    },
    "axis_visible": {
      "showgrid":       true,
      "gridcolor":      "rgba(212, 201, 152, 0.18)",
      "showticklabels": true,
      "zeroline":       false,
      "showline":       false,
      "tickfont":       { "family": "'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, monospace", "size": 9, "color": "#6b7280" }
    }
  },

  "matplotlib": {
    "rcParams": {
      "figure.facecolor":       "#1b2430",
      "axes.facecolor":         "#222d3b",
      "savefig.facecolor":      "#1b2430",
      "text.color":             "#e8e4d4",
      "axes.labelcolor":        "#9da89a",
      "axes.edgecolor":         "#8a8366",
      "xtick.color":            "#9da89a",
      "ytick.color":            "#9da89a",
      "grid.color":             "rgba(212, 201, 152, 0.18)",
      "grid.linestyle":         "dotted",
      "axes.grid":              true,
      "axes.prop_cycle":        "cycler('color', ['#9dc797', '#e4c571', '#e26d6d', '#d4c998', '#b8dab2', '#d97706'])",
      "font.family":            "monospace",
      "font.monospace":         ["JetBrains Mono", "SF Mono", "Menlo", "Courier New"],
      "font.size":              11,
      "axes.titlesize":         13,
      "axes.titleweight":       "bold",
      "axes.titlelocation":     "left",
      "axes.titlepad":          12,
      "axes.labelsize":         11,
      "axes.spines.top":        false,
      "axes.spines.right":      false,
      "figure.titlesize":       14,
      "figure.titleweight":     "bold"
    }
  },

  "semantic": {
    "kind": {
      "fleet":      { "color": "#9dc797", "description": "Event log — aggregate fleet drop/spike" },
      "state":      { "color": "#e4c571", "description": "Event log — per-block status transition" },
      "optimizer":  { "color": "#9dc797", "description": "Event log — retune batch" },
      "predicter":  { "color": "#e26d6d", "description": "Event log — safety action" },
      "dataset":    { "color": "#d4c998", "description": "Event log — telemetry gain/loss" }
    },
    "severity": {
      "info": { "color": "#9da89a" },
      "warn": { "color": "#e4c571" },
      "crit": { "color": "#e26d6d" }
    },
    "miner_status": {
      "ok":   { "color": "#9dc797", "label": "safe",     "range": "TTF > 24h" },
      "warn": { "color": "#e4c571", "label": "warning",  "range": "TTF 6–24h" },
      "imm":  { "color": "#e26d6d", "label": "imminent", "range": "TTF < 6h" },
      "shut": { "color": "#6b7280", "label": "shutdown", "range": "locked" }
    }
  }
}
